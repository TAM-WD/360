{
  "manifest_version": 3,
  "name": "Support Center Helper",
  "version": "2.4",
  "description": "Расширение для работы с Support Center",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://admin.yandex.ru/*",
    "https://admin.360.yandex.ru/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://admin.yandex.ru/*",
        "https://admin.360.yandex.ru/*"
      ],
      "js": ["injector.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://admin.yandex.ru/*",
        "https://admin.360.yandex.ru/*"
      ],
      "js": ["content.js"],
      "css": ["navigation.css"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js", "navigation.js"],
      "matches": [
        "https://admin.yandex.ru/*",
        "https://admin.360.yandex.ru/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}